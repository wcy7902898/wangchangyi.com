# Cloudflare Pages security headers (2026-06-25 一辉配)
# 部署到 wangchangyi.com 后 CF Pages edge 自动应用

/*
  # HTTP 严格传输安全(HSTS,1 年) - 强制 HTTPS,防止降级攻击
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # 防止 MIME 类型嗅探攻击
  X-Content-Type-Options: nosniff

  # 点击劫持保护
  X-Frame-Options: DENY

  # Referrer 控制 - 只发同源 referrer
  Referrer-Policy: strict-origin-when-cross-origin

  # 浏览器特性权限(精简)
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()

  # 内容安全策略(Content Security Policy)
  # script-src: self + unsafe-inline(Blowfish 内联脚本) + giscus.app(Giscus 评论)
  # style-src: self + unsafe-inline(Blowfish 内联样式)
  # img-src: self + https(Giscus 头像) + data(内联图片)
  # connect-src: self + api.github.com(Giscus API)
  # frame-src: giscus.app(Giscus iframe)
  Content-Security-Policy: default-src 'self'; img-src 'self' data: https:; script-src 'self' 'unsafe-inline' https://giscus.app https://*.giscus.app https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://giscus.app; font-src 'self' data: https://giscus.app; connect-src 'self' https://api.github.com https://cloudflareinsights.com; frame-ancestors 'none'; frame-src https://giscus.app; base-uri 'self'; form-action 'self'